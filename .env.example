# AutoApply Configuration
# Copy this to .env and fill in your details

# LLM — Groq is primary (free, fast, Llama3-70B)
# Get your free API key at: https://console.groq.com
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# LLM Fallback — Ollama for fully offline usage (optional)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
LLM_TIMEOUT=120

# Job Discovery
SEARCH_QUERIES=Strategy Operations Analyst,Business Transformation Consultant,Management Consulting entry level
TARGET_LOCATIONS=United States,Remote
MAX_JOBS_PER_CYCLE=10
CYCLES_PER_RUN=10

# RPA Browser Automation
HEADLESS_BROWSER=true
SCREENSHOT_ON_APPLY=true
SKIP_CUSTOM_QUESTIONS=true
APPLY_DELAY_SECONDS=5

# Schedule (24hr format, comma-separated)
RUN_TIMES=08:00,18:00

# Database
DATABASE_URL=sqlite:///data/autoapply.db
